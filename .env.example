# Local development
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Production (required when DJANGO_DEBUG=0)
# DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# DJANGO_ALLOWED_HOSTS=example.com,.vercel.app

# Optional: override sqlite location
# DJANGO_DB_PATH=C:\path\to\db.sqlite3

# Optional: security overrides (used when DJANGO_DEBUG=0)
# DJANGO_SECURE_SSL_REDIRECT=1
# DJANGO_SECURE_HSTS_SECONDS=31536000
